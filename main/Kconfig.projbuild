menu "StudioPieters"

    config ESP_LED_GPIO
        int "Identify LED GPIO"
        default 23
        help
            GPIO for the HomeKit identify LED. Blinks on HomeKit identify
            request. Not exposed as a HomeKit service.

    config ESP_BUTTON_GPIO
        int "Physical button GPIO"
        default 25
        help
            GPIO for the physical push button wired GND -> button -> GPIO.
            Uses active-low logic with internal pull-up enabled in main.c.
            Avoid bootstrapping pins (0, 2, 5, 12, 15).
            Single press: OTA update/reboot.
            Double press: HomeKit reset + restart.
            Long press: factory reset + reboot.

    config ESP_RELAY_OPEN_GPIO
        int "OPEN (UP) relay GPIO"
        default 16
        help
            GPIO driving the relay that opens / raises the sunshade.
            Never activated simultaneously with the CLOSE relay.

    config ESP_RELAY_CLOSE_GPIO
        int "CLOSE (DOWN) relay GPIO"
        default 17
        help
            GPIO driving the relay that closes / lowers the sunshade.
            Never activated simultaneously with the OPEN relay.

    config ESP_TTP_UP_GPIO
        int "TTP223 UP signal GPIO"
        default 32
        help
            Digital signal from the UP TTP223 touch module.

    config ESP_TTP_STOP_GPIO
        int "TTP223 STOP signal GPIO"
        default 33
        help
            Digital signal from the STOP TTP223 touch module.

    config ESP_TTP_DOWN_GPIO
        int "TTP223 DOWN signal GPIO"
        default 27
        help
            Digital signal from the DOWN TTP223 touch module.

    config ESP_TTP_ACTIVE_LEVEL
        int "TTP223 active level"
        default 1
        range 0 1
        help
            Use 1 for active-high TTP223 modules.
            Use 0 only if your module is configured as active-low.

    config ESP_TTP_POLL_MS
        int "TTP223 poll interval (ms)"
        default 25
        range 10 200
        help
            Polling interval for the TTP223 digital inputs.

    config ESP_TTP_DEBOUNCE_MS
        int "TTP223 debounce time (ms)"
        default 60
        range 10 500
        help
            Debounce time for stable TTP223 touch detection.

    config SUNSHADE_FULL_TRAVEL_TIME_MS
        int "Full travel time (ms)"
        default 20000
        range 1000 120000
        help
            Time in milliseconds for the sunshade motor to travel the full
            distance from 0 % to 100 %, or vice versa. Used for time-based
            position estimation when not calibrated.

    config ESP_SETUP_CODE
        string "HomeKit Setup Code"
        default "582-94-633"
        help
            HomeKit pairing code. Changing this value requires a new QR code.

    config ESP_SETUP_ID
        string "HomeKit Setup ID"
        default "7MX2"
        help
            HomeKit setup ID. Changing this value requires a new QR code.

endmenu
